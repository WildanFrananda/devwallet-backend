NODE_ENV=development
PORT=3000

# Database
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=devwallet
DATABASE_PASSWORD=devwallet_dev
DATABASE_NAME=devwallet

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Local chain nodes (Phase 0 not required, isi nanti)
ANVIL_RPC_URL=http://localhost:8545
SOLANA_RPC_URL=http://localhost:8899

# ===== Firebase Cloud Messaging =====
# FIREBASE_ADMIN_KEY_PATH points to an absolute path to the service-account
# JSON file. Never commit the key itself. Recommended location during dev:
# `~/secrets/devwallet/firebase-admin.json`. Phase 2 reads the file at boot
# via firebase-admin's cert() helper.
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_KEY_PATH=

# ===== Faucet provider API keys (Phase 2 F-02) =====
# Free-tier signup links documented in faucet_providers_setup_tutorial.md.
# Leave blank for providers that do not require a key (bitcoin/cosmos/xrpl).

# Alchemy — per-chain key (each network has its own app in the dashboard).
ALCHEMY_API_KEY_SEPOLIA=
ALCHEMY_API_KEY_AMOY=
ALCHEMY_API_KEY_STARKNET=

# Helius — single key works for devnet + mainnet routes.
HELIUS_API_KEY=

# Coinbase Cloud (CDP) — JWT auth pair. PRIVATE_KEY is the EC PEM.
COINBASE_API_KEY_ID=
COINBASE_API_KEY_PRIVATE_KEY=

# ===== Sponsor wallets + FaucetDispenser contracts (Phase 2 own-contract faucet) =====
# Generated locally per chain via `cast wallet new` and funded ONCE via public
# testnet web faucets (captcha). Never reuse these keys for mainnet. Never
# commit the real values — gitignored.
SEPOLIA_SPONSOR_PRIVATE_KEY=
SEPOLIA_FAUCET_CONTRACT=
SEPOLIA_RPC_URL=https://1rpc.io/sepolia

AMOY_SPONSOR_PRIVATE_KEY=
AMOY_FAUCET_CONTRACT=
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

BASE_SEPOLIA_SPONSOR_PRIVATE_KEY=
BASE_SEPOLIA_FAUCET_CONTRACT=
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Solana devnet sponsor (Anchor dev_faucet program).
# SOLANA_SPONSOR_KEYPAIR_JSON = full keypair byte array (paste exact content of
# `~/.config/solana/id.json` between quotes — JSON array of 64 numbers).
# Or set SOLANA_SPONSOR_KEYPAIR_PATH to absolute path on disk.
SOLANA_SPONSOR_KEYPAIR_PATH=
SOLANA_SPONSOR_KEYPAIR_JSON=
SOLANA_FAUCET_PROGRAM_ID=2UhnWRa3Pu4BqTN7xnZG9jxkmz3cgCEC2AF2Jh5MKgCY
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com